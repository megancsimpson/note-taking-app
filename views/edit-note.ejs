<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-5W0EZpGmCU5+M8G6k6kRvqY0C30tSXf98gkBCx9hqHV+Ic5Dbon2kzvPT2JZ9twd" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-soft">
  <div class="app-shell min-vh-100 d-flex flex-column">

    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/">Note App</a>
        <nav class="nav-links">
          <a class="nav-link-custom" href="/">Home</a>
          <a class="nav-link-custom" href="/notes">Notes</a>
          <a class="nav-link-custom" href="/about">About</a>
        </nav>
        <div class="header-cta">
          <% if (user) { %>
            <a class="nav-link-custom" href="/logout">Sign out</a>
          <% } else { %>
            <a class="nav-link-custom" href="/auth/google">Login</a>
          <% } %>
        </div>
      </div>
    </header>

    <main class="page-content flex-grow-1">
      <div class="notes-header mb-4 d-flex flex-column gap-3">
        <div>
          <h1 class="page-title mb-2"><%= title %></h1>
          <p class="section-copy">Edit your note in a calm, clear space.</p>
        </div>
        <div class="text-muted small">
          Signed in as <strong><%= user.displayName %></strong>
          <br>
          Created: <%= new Date(note.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
        </div>
      </div>

      <div class="card shadow-sm rounded-4 border-0 p-4">
        <form id="edit-note-form" action="/notes/<%= note._id %>" method="POST" class="d-flex flex-column gap-3">
          <input type="hidden" name="_method" value="PUT">
          <div>
            <label class="form-label fw-semibold">Title</label>
            <input class="form-control" type="text" name="title" value="<%= note.title %>" required>
          </div>

          <!-- Formatting toolbar (Quill) -->
          <div id="quill-toolbar" class="mb-2">
            <select class="ql-header" title="Heading">
              <option selected></option>
              <option value="1">H1</option>
              <option value="2">H2</option>
              <option value="3">H3</option>
            </select>
            <button class="ql-bold" title="Bold"></button>
            <button class="ql-italic" title="Italic"></button>
            <button class="ql-underline" title="Underline"></button>
            <button class="ql-strike" title="Strikethrough"></button>
            <button class="ql-list" value="ordered" title="Numbered list"></button>
            <button class="ql-list" value="bullet" title="Bulleted list"></button>
            <button id="ql-check" type="button" title="Checklist">☑</button>
          </div>

          <!-- Editor -->
          <div id="editor" class="mb-2" style="min-height: 320px;"></div>

          <!-- Hidden input to send HTML content -->
          <input type="hidden" name="content" id="content-input">

          <div class="d-flex flex-column flex-sm-row gap-3 align-items-center justify-content-end">
            <a class="btn-clear" href="/notes">Cancel</a>

            <form id="delete-form" action="/notes/<%= note._id %>" method="POST" class="m-0">
              <input type="hidden" name="_method" value="DELETE">
              <button id="delete-button" class="btn-modern btn-modern-danger" type="submit">Delete</button>
            </form>

            <button class="btn-modern btn-modern-primary" id="save-button" type="submit">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12.5l4 4L19 7" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <span class="ms-2">Update note</span>
            </button>
          </div>
        </form>
      </div>

      <!-- Quill resources and initialization -->
      <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
      <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
      <style>
        /* Small page-specific styles to keep editor clean and responsive */
        #quill-toolbar { display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
        #quill-toolbar .ql-header { padding:6px 8px; border-radius:8px; border:1px solid rgba(15,23,42,0.06); }
        #quill-toolbar button { background:transparent; border:1px solid rgba(15,23,42,0.04); border-radius:8px; padding:6px 8px; }
        #editor .ql-editor { font-family: Inter, "Segoe UI", system-ui, -apple-system, "Helvetica Neue", Arial; font-size:16px; line-height:1.6; }
        #editor { border:1px solid rgba(15,23,42,0.06); border-radius:10px; background:var(--surface); padding:12px; }
        @media (max-width:640px){ #editor{min-height:220px} }
      </style>

      <script>
        (function(){
          var toolbarOptions = '#quill-toolbar';
          var quill = new Quill('#editor', {
            modules: {
              toolbar: toolbarOptions,
              history: { delay: 1000, maxStack: 500, userOnly: true }
            },
            placeholder: 'Write your note here…',
            theme: 'snow'
          });

          // Load existing HTML content (unescaped)
          var existing = `<%- (note.content || '') %>`;
          if (existing) {
            quill.clipboard.dangerouslyPasteHTML(existing);
          }

          // Checklist toggle: attempt to set list format to 'checked' for checkbox lists
          document.getElementById('ql-check').addEventListener('click', function(){
            var range = quill.getSelection(true);
            if(!range) return;
            var formats = quill.getFormat(range);
            var current = formats['list'];
            if(current === 'checked') {
              quill.format('list', false);
            } else {
              quill.format('list', 'checked');
            }
          });

          // On form submit: put HTML into hidden input
          var form = document.getElementById('edit-note-form');
          form.addEventListener('submit', function(e){
            var html = quill.root.innerHTML;
            document.getElementById('content-input').value = html;
          });

          // Confirm delete
          var delForm = document.getElementById('delete-form');
          delForm.addEventListener('submit', function(e){
            if(!confirm('Delete this note? This action cannot be undone.')) e.preventDefault();
          });
        })();
      </script>
    </main>

    <footer class="footer mt-auto py-5">
      <div class="footer-description mx-auto px-3 mb-4">
        <p class="text-muted mb-0">A full-stack note-taking application built to demonstrate server-side JavaScript, API development, and seamless integration between the front-end and back-end.</p>
      </div>
      <div class="footer-grid mx-auto px-3">
        <div class="footer-column">
          <p class="footer-label mb-2">Built with</p>
          <p class="mb-1">JavaScript · Node.js · Express · MongoDB</p>
          <p class="mb-1">Mongoose · EJS · Bootstrap</p>
          <p class="mb-0">Passport / Google OAuth</p>
        </div>
        <div class="footer-column">
          <p class="footer-label mb-2">Contact</p>
          <p class="mb-1">megancatherinesimpson@gmail.com</p>
          <p class="mb-1"><a href="https://linkedin.com/in/megancsimpson" target="_blank">linkedin.com/in/megancsimpson</a></p>
          <p class="mb-0">GitHub: <a href="#" class="footer-link">github.com/megan-simpson</a></p>
        </div>
        <div class="footer-column">
          <p class="footer-label mb-2">Made by</p>
          <p class="mb-0">Megan Simpson</p>
          <p class="mb-0">Software development student</p>
        </div>
        <div class="footer-note text-center text-muted">
          <p class="mb-0">© 2026 Megan Simpson</p>
        </div>
      </div>
    </footer>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-d93c3Mvqd6i8x7hYaI7v55dB6Y4TRFaLMfv6VxsgQ1z0B9VIjK1Qgx9JCYFDVg71" crossorigin="anonymous"></script>
</body>
</html>
