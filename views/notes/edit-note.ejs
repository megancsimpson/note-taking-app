<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-5W0EZpGmCU5+M8G6k6kRvqY0C30tSXf98gkBCx9hqHV+Ic5Dbon2kzvPT2JZ9twd" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles/styles.css">
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
  <%- include('../partials/ui-overrides') %>
</head>
<body class="bg-soft">
  <div class="app-shell min-vh-100 d-flex flex-column">
    <%- include('../partials/header', { user: user }) %>

    <main id="main-content" class="page-content flex-grow-1">
      <section class="surface-stack editor-page">
      <div class="notes-header editor-header-minimal">
        <div class="editor-header-copy">
          <h1 class="page-title mb-0">Edit</h1>
          <p class="user-identity-line">Logged in as: <strong><%= user.displayName %></strong></p>
        </div>
      </div>

        <form id="edit-note-form" action="/notes/<%= note._id %>" method="POST" class="editor-form d-flex flex-column gap-3">
          <input type="hidden" name="_method" value="PUT">
          <div class="editor-shell">
            <div class="editor-surface">
              <div class="editor-toolbar-shell">
              <div id="quill-toolbar" role="toolbar" aria-label="Note formatting toolbar">
                <select class="ql-header" title="Heading" aria-label="Heading level">
                  <option selected></option>
                  <option value="1">H1</option>
                  <option value="2">H2</option>
                  <option value="3">H3</option>
                </select>
                <button class="ql-bold" type="button" title="Bold" aria-label="Bold"></button>
                <button class="ql-italic" type="button" title="Italic" aria-label="Italic"></button>
                <button class="ql-underline" type="button" title="Underline" aria-label="Underline"></button>
                <button class="ql-strike" type="button" title="Strikethrough" aria-label="Strikethrough"></button>
                <button class="ql-list" type="button" value="ordered" title="Numbered list" aria-label="Numbered list"></button>
                <button class="ql-list" type="button" value="bullet" title="Bulleted list" aria-label="Bulleted list"></button>
                <button id="ql-check" type="button" title="Checklist" aria-label="Checklist">☑</button>
              </div>
              </div>

              <div class="editor-region">
                <div
                  id="title-editor"
                  class="note-title-editor"
                  contenteditable="true"
                  role="textbox"
                  aria-label="Note title"
                  data-placeholder="Title"
                ><%= note.title %></div>
                <div id="editor"></div>
              </div>

              <div class="editor-actions editor-actions-inline">
                <a class="btn-clear editor-action editor-action-secondary" href="/notes">Cancel</a>
                <button class="btn-modern editor-action editor-action-primary" id="save-button" type="submit">
                  <span>Save</span>
                </button>
                <button id="delete-button" class="btn-modern editor-action editor-action-danger" type="submit" form="delete-form">Delete</button>
              </div>
            </div>
          </div>

          <input type="hidden" name="title" id="title-input">
          <input type="hidden" name="content" id="content-input">
        </form>
        <form id="delete-form" action="/notes/<%= note._id %>" method="POST" class="delete-form d-none">
          <input type="hidden" name="_method" value="DELETE">
        </form>

      <script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
      <script>
        (function(){
          var toolbarOptions = '#quill-toolbar';
          var quill = new Quill('#editor', {
            modules: {
              toolbar: toolbarOptions,
              history: { delay: 1000, maxStack: 500, userOnly: true }
            },
            placeholder: 'Write your note here',
            theme: 'snow'
          });
          var checklistButton = document.getElementById('ql-check');

          function syncChecklistState() {
            var range = quill.getSelection();
            if (!range) {
              checklistButton.classList.remove('is-active');
              return;
            }

            var formats = quill.getFormat(range);
            checklistButton.classList.toggle('is-active', formats.list === 'checked');
          }

          // Load existing HTML content (unescaped)
          var existing = `<%- (note.content || '') %>`;
          if (existing) {
            quill.clipboard.dangerouslyPasteHTML(existing);
          }

          // Checklist toggle: attempt to set list format to 'checked' for checkbox lists
          checklistButton.addEventListener('click', function(){
            var range = quill.getSelection(true);
            if(!range) return;
            var formats = quill.getFormat(range);
            var current = formats['list'];
            if(current === 'checked') {
              quill.format('list', false);
            } else {
              quill.format('list', 'checked');
            }
            syncChecklistState();
          });

          quill.on('selection-change', syncChecklistState);

          quill.on('text-change', syncChecklistState);

          var titleEditor = document.getElementById('title-editor');
          var titleInput = document.getElementById('title-input');

          function normalizeTitleEditor() {
            if (titleEditor.innerHTML === '<br>' || titleEditor.textContent.trim() === '') {
              titleEditor.innerHTML = '';
            }
          }

          titleEditor.addEventListener('keydown', function(event){
            if (event.key === 'Enter') {
              event.preventDefault();
              quill.focus();
              quill.setSelection(0, 0, 'user');
            }
          });

          titleEditor.addEventListener('input', normalizeTitleEditor);

          // On form submit: put HTML into hidden input
          var form = document.getElementById('edit-note-form');
          form.addEventListener('submit', function(event){
            normalizeTitleEditor();
            titleInput.value = titleEditor.textContent.trim();
            if (!titleInput.value) {
              event.preventDefault();
              titleEditor.focus();
              return;
            }
            var html = quill.root.innerHTML;
            document.getElementById('content-input').value = html;
          });

          // Confirm delete
          var delForm = document.getElementById('delete-form');
          delForm.addEventListener('submit', function(e){
            if(!confirm('Delete this note? This action cannot be undone.')) e.preventDefault();
          });

          syncChecklistState();
        })();
      </script>
      </section>
    </main>

    <%- include('../partials/footer') %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-d93c3Mvqd6i8x7hYaI7v55dB6Y4TRFaLMfv6VxsgQ1z0B9VIjK1Qgx9JCYFDVg71" crossorigin="anonymous"></script>
</body>
</html>
