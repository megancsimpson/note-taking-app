<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-5W0EZpGmCU5+M8G6k6kRvqY0C30tSXf98gkBCx9hqHV+Ic5Dbon2kzvPT2JZ9twd" crossorigin="anonymous">
    <link rel="stylesheet" href="/styles.css">
    <%- include('partials/ui-overrides') %>
</head>
<body class="bg-soft">
  <div class="app-shell min-vh-100 d-flex flex-column">
    <%- include('partials/header', { user: user }) %>

    <main class="page-content flex-grow-1">
      <section class="home-hero">
        <div class="hero-layout">
          <div class="hero-panel-copy">
            <div>
              <h1 class="page-title">Notes</h1>
              <p class="section-copy">A focused workspace for capturing ideas, organizing research, and editing rich notes with a cleaner, more consistent interface.</p>
            </div>
            <div class="header-actions">
              <% if (user) { %>
                <a class="btn-modern btn-modern-primary" href="/notes">Continue to notes</a>
              <% } else { %>
                <a class="btn-modern btn-modern-primary" href="/auth/google">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4Zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4Z" fill="currentColor"/></svg>
                  <span>Login with Google</span>
                </a>
              <% } %>
            </div>
          </div>
          <aside class="hero-support">
            <p class="eyebrow">Designed For</p>
            <p class="mb-2">A full-stack note-taking application built to demonstrate server-side JavaScript, API development, and seamless integration between the front-end and back-end.</p>
          </aside>
        </div>
      </section>
    </main>

    <%- include('partials/footer') %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-d93c3Mvqd6i8x7hYaI7v55dB6Y4TRFaLMfv6VxsgQ1z0B9VIjK1Qgx9JCYFDVg71" crossorigin="anonymous"></script>
</body>
</html>