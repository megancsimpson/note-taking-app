<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-5W0EZpGmCU5+M8G6k6kRvqY0C30tSXf98gkBCx9hqHV+Ic5Dbon2kzvPT2JZ9twd" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles.css">
  <%- include('partials/ui-overrides') %>
</head>
<body class="bg-soft">
  <div class="app-shell min-vh-100 d-flex flex-column">
    <%- include('partials/header', { user: user }) %>

    <main class="page-content flex-grow-1">
      <section class="surface-stack notes-page">
      <div class="notes-header page-topbar">
        <div class="page-section">
          <h1 class="page-title mb-2">Notes</h1>
        </div>
        <a class="btn-modern btn-modern-primary" href="/notes/new">Create</a>
      </div>

      <div class="notes-actions d-flex flex-column flex-md-row align-items-stretch align-items-md-center gap-3">
        <form action="/notes/search" method="GET" class="search-panel search-panel-inline" id="notes-search-form">
          <div class="search-input-shell">
            <input class="form-control" id="notes-search-input" type="text" name="q" placeholder="Search notes..." value="<%= searchQuery || '' %>" aria-label="Search notes" autocomplete="off">
            <button class="search-inline-clear <%= searchQuery ? 'is-visible' : '' %>" id="notes-search-clear" type="button" aria-label="Clear search">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
            </button>
          </div>
        </form>
      </div>

      <div class="notes-list">
        <% if (displayMessage) { %>
          <div class="alert alert-info mb-0"> <%= displayMessage %> </div>
        <% } %>
        <% if (notes.length > 0) { %>
          <div class="notes-stream">
            <% notes.forEach((note) => { %>
              <article class="note-card">
                <div class="note-card-layout">
                  <div class="note-card-copy">
                    <h3 class="h5 mb-2"><%= note.title %></h3>
                    <p class="note-summary mb-3"><%= note.preview || 'No content available' %></p>
                    <p class="text-muted small mb-0">Created: <%= new Date(note.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                  </div>
                  <div class="note-action-bar">
                    <a class="icon-action" href="/notes/<%= note._id %>/edit" aria-label="Edit note">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 21v-3.75L14.81 5.44a2 2 0 0 1 2.83 0l1.92 1.92a2 2 0 0 1 0 2.83L7.75 21H3z" fill="currentColor"/></svg>
                    </a>
                    <form action="/notes/<%= note._id %>" method="POST" class="m-0">
                      <input type="hidden" name="_method" value="DELETE">
                      <button class="btn-icon" type="submit" aria-label="Delete note">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M8 6v12a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V6M10 6V4a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                      </button>
                    </form>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
        <% } else if (!displayMessage) { %>
          <div class="empty-state">
            <p class="text-muted mb-0">No notes found yet. Start with the form above to create your first note.</p>
          </div>
        <% } %>
      </div>
      </section>
    </main>
    <%- include('partials/footer') %>
  </div>
  <script>
    (function () {
      var searchInput = document.getElementById('notes-search-input');
      var clearButton = document.getElementById('notes-search-clear');
      if (!searchInput || !clearButton) return;

      function syncClearVisibility() {
        clearButton.classList.toggle('is-visible', searchInput.value.trim().length > 0);
      }

      clearButton.addEventListener('click', function () {
        if (!searchInput.value.trim()) {
          window.location.href = '/notes';
          return;
        }

        searchInput.value = '';
        syncClearVisibility();
        window.location.href = '/notes';
      });

      searchInput.addEventListener('input', syncClearVisibility);
      syncClearVisibility();
    })();
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-d93c3Mvqd6i8x7hYaI7v55dB6Y4TRFaLMfv6VxsgQ1z0B9VIjK1Qgx9JCYFDVg71" crossorigin="anonymous"></script>
</body>
</html>
