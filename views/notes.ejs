<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-5W0EZpGmCU5+M8G6k6kRvqY0C30tSXf98gkBCx9hqHV+Ic5Dbon2kzvPT2JZ9twd" crossorigin="anonymous">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="bg-soft">
  <div class="app-shell min-vh-100 d-flex flex-column">

    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/">Note App</a>
        <nav class="nav-links">
          <a class="nav-link-custom" href="/">Home</a>
          <a class="nav-link-custom" href="/notes">Notes</a>
          <a class="nav-link-custom" href="/about">About</a>
        </nav>
        <div class="header-cta">
          <% if (user) { %>
            <a class="nav-link-custom" href="/logout">Sign out</a>
          <% } else { %>
            <a class="nav-link-custom" href="/auth/google">Login</a>
          <% } %>
        </div>
      </div>
    </header>

    <main class="page-content flex-grow-1">
      <div class="notes-header mb-4 d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
        <div>
          <h1 class="page-title mb-2">My Notes</h1>
          <p class="section-copy">Search by title or create a new note to keep your ideas organized.</p>
        </div>
        <a class="btn-modern btn-modern-primary" href="/notes/new">Create Note</a>
      </div>

      <div class="notes-actions mb-4 d-flex flex-column flex-md-row align-items-stretch align-items-md-center gap-3">
        <form action="/notes/search" method="GET" class="search-panel">
          <input class="form-control" type="text" name="q" placeholder="Search notes..." value="<%= searchQuery || '' %>" aria-label="Search notes">
          <button class="btn-modern btn-modern-outline" type="submit">Search</button>
        </form>
        <% if (searchQuery) { %>
          <a class="btn-clear" href="/notes">Clear search</a>
        <% } %>
      </div>

      <div class="notes-list">
        <% if (displayMessage) { %>
          <div class="alert alert-info rounded-4 mb-4"> <%= displayMessage %> </div>
        <% } %>
        <% if (notes.length > 0) { %>
          <div class="row g-3">
            <% notes.forEach((note) => { %>
              <div class="col-12">
                <article class="note-card card rounded-4 border-0 shadow-sm p-4 bg-light">
                  <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3">
                    <div class="flex-grow-1">
                      <h3 class="h5 mb-2"><%= note.title %></h3>
                      <p class="note-summary mb-3"><%= note.preview || note.title || 'No content available' %></p>
                      <p class="text-muted small mb-0">Created: <%= new Date(note.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                    </div>
                    <div class="d-flex gap-2 flex-column align-items-start align-items-md-end">
                      <a class="btn-modern btn-modern-outline btn-sm d-inline-flex align-items-center gap-2" href="/notes/<%= note._id %>/edit">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M3 21v-3.75L14.81 5.44a2 2 0 0 1 2.83 0l1.92 1.92a2 2 0 0 1 0 2.83L7.75 21H3z" fill="currentColor"/></svg>
                        <span>Edit</span>
                      </a>
                      <form action="/notes/<%= note._id %>" method="POST" class="m-0">
                        <input type="hidden" name="_method" value="DELETE">
                        <button class="btn-icon" type="submit" aria-label="Delete note">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path d="M3 6h18M8 6v12a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V6M10 6V4a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                        </button>
                      </form>
                    </div>
                  </div>
                </article>
              </div>
            <% }) %>
          </div>
        <% } else if (!displayMessage) { %>
          <div class="p-4 bg-white rounded-4 border border-dashed border-secondary">
            <p class="text-muted mb-0">No notes found yet. Start with the form above to create your first note.</p>
          </div>
        <% } %>
      </div>
    </main>
    <footer class="footer mt-auto py-5">
      <div class="footer-description mx-auto px-3 mb-4">
        <p class="text-muted mb-0">A full-stack note-taking application built to demonstrate server-side JavaScript, API development, and seamless integration between the front-end and back-end.</p>
      </div>
      <div class="footer-grid mx-auto px-3">
        <div class="footer-column">
          <p class="footer-label mb-2">Built with</p>
          <p class="mb-1">JavaScript · Node.js · Express · MongoDB</p>
          <p class="mb-1">Mongoose · EJS · Bootstrap</p>
          <p class="mb-0">Passport / Google OAuth</p>
        </div>
        <div class="footer-column">
          <p class="footer-label mb-2">Contact</p>
          <p class="mb-1">megancatherinesimpson@gmail.com</p>
          <p class="mb-1"><a href="https://linkedin.com/in/megancsimpson" target="_blank">linkedin.com/in/megancsimpson</a></p>
          <p class="mb-0">GitHub: <a href="#" class="footer-link">github.com/megan-simpson</a></p>
        </div>
        <div class="footer-column">
          <p class="footer-label mb-2">Made by</p>
          <p class="mb-0">Megan Simpson</p>
          <p class="mb-0">Software development student</p>
        </div>
        <div class="footer-note text-center text-muted">
          <p class="mb-0">© 2026 Megan Simpson</p>
        </div>
      </div>
    </footer>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-d93c3Mvqd6i8x7hYaI7v55dB6Y4TRFaLMfv6VxsgQ1z0B9VIjK1Qgx9JCYFDVg71" crossorigin="anonymous"></script>
</body>
</html>
